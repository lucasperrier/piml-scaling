\newlabel{sec:results-plain}{{7.1}{6}{Plain MLP baseline: scaling behavior}{subsection.7.1}{}}
\newlabel{sec:results-plain@cref}{{[subsection][1][7]7.1}{[1][5][]6}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Data scaling for the plain MLP and midpoint PIML models. Left to right: small, medium, and large capacity. The plain MLP (blue circles) exhibits clean power-law decay with exponent $\hat  {\beta } \approx 0.85$. The midpoint-residual PIML (red squares) saturates at $E \approx 0.014$--$0.016$ regardless of dataset size, reflecting the irreducible physics-loss floor.}}{6}{figure.1}\protected@file@percent }
\newlabel{fig:data-scaling}{{1}{6}{Data scaling for the plain MLP and midpoint PIML models. Left to right: small, medium, and large capacity. The plain MLP (blue circles) exhibits clean power-law decay with exponent $\hat {\beta } \approx 0.85$. The midpoint-residual PIML (red squares) saturates at $E \approx 0.014$--$0.016$ regardless of dataset size, reflecting the irreducible physics-loss floor}{figure.1}{}}
\newlabel{fig:data-scaling@cref}{{[figure][1][]1}{[1][6][]6}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.2}ODE-residual prior: biased scaling}{6}{subsection.7.2}\protected@file@percent }
\newlabel{sec:results-midpoint}{{7.2}{6}{ODE-residual prior: biased scaling}{subsection.7.2}{}}
\newlabel{sec:results-midpoint@cref}{{[subsection][2][7]7.2}{[1][6][]6}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Capacity scaling: test error versus parameter count $N$ at representative dataset sizes. The plain MLP (blue) follows a power law with $\hat  {\alpha } \approx 0.91$. The midpoint PIML (red) shows minimal improvement beyond the physics-loss plateau.}}{7}{figure.2}\protected@file@percent }
\newlabel{fig:capacity-scaling}{{2}{7}{Capacity scaling: test error versus parameter count $N$ at representative dataset sizes. The plain MLP (blue) follows a power law with $\hat {\alpha } \approx 0.91$. The midpoint PIML (red) shows minimal improvement beyond the physics-loss plateau}{figure.2}{}}
\newlabel{fig:capacity-scaling@cref}{{[figure][2][]2}{[1][6][]7}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Comparative data scaling at large capacity ($N = 67{,}074$). The plain MLP continues to improve with data, while the midpoint-residual PIML saturates at $E \approx 0.014$, determined by the biased physics-loss floor rather than data availability.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:midpoint-vs-plain}{{3}{8}{Comparative data scaling at large capacity ($N = 67{,}074$). The plain MLP continues to improve with data, while the midpoint-residual PIML saturates at $E \approx 0.014$, determined by the biased physics-loss floor rather than data availability}{figure.3}{}}
\newlabel{fig:midpoint-vs-plain@cref}{{[figure][3][]3}{[1][7][]8}}
