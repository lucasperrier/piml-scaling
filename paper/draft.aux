\newlabel{sec:results-plain}{{7.1}{7}{Plain MLP baseline: scaling behavior}{subsection.7.1}{}}
\newlabel{sec:results-plain@cref}{{[subsection][1][7]7.1}{[1][7][]7}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Data scaling for all three scaling-law models. Left to right: small, medium, and large capacity. The plain MLP (blue circles) exhibits clean power-law decay with exponent $\hat  {\beta } \approx 0.85$. The midpoint-residual PIML (red squares) saturates at $E \approx 0.014$--$0.016$. The composite midpoint PIML (green diamonds) tracks below the midpoint and above the plain baseline, with steeper scaling.}}{7}{figure.1}\protected@file@percent }
\newlabel{fig:data-scaling}{{1}{7}{Data scaling for all three scaling-law models. Left to right: small, medium, and large capacity. The plain MLP (blue circles) exhibits clean power-law decay with exponent $\hat {\beta } \approx 0.85$. The midpoint-residual PIML (red squares) saturates at $E \approx 0.014$--$0.016$. The composite midpoint PIML (green diamonds) tracks below the midpoint and above the plain baseline, with steeper scaling}{figure.1}{}}
\newlabel{fig:data-scaling@cref}{{[figure][1][]1}{[1][7][]7}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.2}ODE-residual prior: biased scaling}{8}{subsection.7.2}\protected@file@percent }
\newlabel{sec:results-midpoint}{{7.2}{8}{ODE-residual prior: biased scaling}{subsection.7.2}{}}
\newlabel{sec:results-midpoint@cref}{{[subsection][2][7]7.2}{[1][7][]8}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Capacity scaling: test error versus parameter count $N$ at representative dataset sizes. The plain MLP (blue) follows a power law with $\hat  {\alpha } \approx 0.93$. The midpoint PIML (red) shows minimal improvement beyond the physics-loss plateau. The composite PIML (green) exhibits steep capacity scaling, approaching the plain baseline at large $N$.}}{8}{figure.2}\protected@file@percent }
\newlabel{fig:capacity-scaling}{{2}{8}{Capacity scaling: test error versus parameter count $N$ at representative dataset sizes. The plain MLP (blue) follows a power law with $\hat {\alpha } \approx 0.93$. The midpoint PIML (red) shows minimal improvement beyond the physics-loss plateau. The composite PIML (green) exhibits steep capacity scaling, approaching the plain baseline at large $N$}{figure.2}{}}
\newlabel{fig:capacity-scaling@cref}{{[figure][2][]2}{[1][7][]8}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Comparative data scaling at large capacity ($N = 67{,}074$). The plain MLP (blue) continues to improve with data. The midpoint PIML (red) saturates at $E \approx 0.014$, limited by the biased physics-loss floor. The composite PIML (green) tracks $\sim \!1.5\times $ above the plain baseline but declines steadily, reflecting recovered data scaling with a small residual floor.}}{9}{figure.3}\protected@file@percent }
\newlabel{fig:midpoint-vs-plain}{{3}{9}{Comparative data scaling at large capacity ($N = 67{,}074$). The plain MLP (blue) continues to improve with data. The midpoint PIML (red) saturates at $E \approx 0.014$, limited by the biased physics-loss floor. The composite PIML (green) tracks $\sim \!1.5\times $ above the plain baseline but declines steadily, reflecting recovered data scaling with a small residual floor}{figure.3}{}}
\newlabel{fig:midpoint-vs-plain@cref}{{[figure][3][]3}{[1][8][]9}}
