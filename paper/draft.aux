\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Error surface $E(N,D)$ for the plain MLP (left) and midpoint PIML (right). The plain model shows a smooth gradient from high error (low $N$, low $D$) to low error (high $N$, high $D$). The PIML model is dominated by a uniform plateau near $E \approx 0.015$.}}{10}{figure.4}\protected@file@percent }
\newlabel{fig:error-heatmap}{{4}{10}{Error surface $E(N,D)$ for the plain MLP (left) and midpoint PIML (right). The plain model shows a smooth gradient from high error (low $N$, low $D$) to low error (high $N$, high $D$). The PIML model is dominated by a uniform plateau near $E \approx 0.015$}{figure.4}{}}
\newlabel{fig:error-heatmap@cref}{{[figure][4][]4}{[1][9][]10}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Fitted scaling exponents with 95\% bootstrap confidence intervals from the joint $E(N,D)$ surface fit. Left: capacity exponent $\alpha $. Right: data exponent $\beta $. The midpoint PIML exponents are substantially smaller, reflecting the dominance of the physics-loss floor over both scaling axes.}}{10}{figure.5}\protected@file@percent }
\newlabel{fig:exponent-comparison}{{5}{10}{Fitted scaling exponents with 95\% bootstrap confidence intervals from the joint $E(N,D)$ surface fit. Left: capacity exponent $\alpha $. Right: data exponent $\beta $. The midpoint PIML exponents are substantially smaller, reflecting the dominance of the physics-loss floor over both scaling axes}{figure.5}{}}
\newlabel{fig:exponent-comparison@cref}{{[figure][5][]5}{[1][10][]10}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Fitted scaling parameters and failure modes across the three models.}}{10}{table.1}\protected@file@percent }
\newlabel{tab:scaling-params}{{1}{10}{Fitted scaling parameters and failure modes across the three models}{table.1}{}}
\newlabel{tab:scaling-params@cref}{{[table][1][]1}{[1][10][]10}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.5}Training stability}{11}{subsection.7.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Training stability summary. Left: divergence rate versus dataset size (zero for both models across all configurations). Right: seed-to-seed variance of test error, showing that the midpoint PIML exhibits lower variance (converging consistently to the physics-loss plateau) while the plain MLP shows higher variance at small $D$.}}{11}{figure.6}\protected@file@percent }
\newlabel{fig:stability}{{6}{11}{Training stability summary. Left: divergence rate versus dataset size (zero for both models across all configurations). Right: seed-to-seed variance of test error, showing that the midpoint PIML exhibits lower variance (converging consistently to the physics-loss plateau) while the plain MLP shows higher variance at small $D$}{figure.6}{}}
\newlabel{fig:stability@cref}{{[figure][6][]6}{[1][11][]11}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.6}Sensitivity to regularization strength}{11}{subsection.7.6}\protected@file@percent }
\newlabel{sec:results-lambda}{{7.6}{11}{Sensitivity to regularization strength}{subsection.7.6}{}}
\newlabel{sec:results-lambda@cref}{{[subsection][6][7]7.6}{[1][11][]11}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Midpoint-prior $\lambda _{\mathrm  {phys}}$ sweep: test relative $\ell _2$ error (mean over 9 replicates).}}{11}{table.2}\protected@file@percent }
\newlabel{tab:lambda-midpoint}{{2}{11}{Midpoint-prior $\lambda _{\mathrm {phys}}$ sweep: test relative $\ell _2$ error (mean over 9 replicates)}{table.2}{}}
\newlabel{tab:lambda-midpoint@cref}{{[table][2][]2}{[1][11][]11}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Midpoint-residual prior: $\lambda _{\mathrm  {phys}}$ sensitivity at small (left) and large (right) capacities. The monotonic dose--response pattern is characteristic of a biased prior: increasing $\lambda $ smoothly degrades performance, with no beneficial regime.}}{12}{figure.7}\protected@file@percent }
\newlabel{fig:lambda-midpoint}{{7}{12}{Midpoint-residual prior: $\lambda _{\mathrm {phys}}$ sensitivity at small (left) and large (right) capacities. The monotonic dose--response pattern is characteristic of a biased prior: increasing $\lambda $ smoothly degrades performance, with no beneficial regime}{figure.7}{}}
\newlabel{fig:lambda-midpoint@cref}{{[figure][7][]7}{[1][12][]12}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Conservation-law prior: $\lambda _{\mathrm  {phys}}$ sensitivity at small (left) and large (right) capacities. Unlike the midpoint prior's smooth degradation, the conservation prior shows non-monotonic behavior with seed-dependent trapping, particularly for the large model at intermediate $\lambda $ values.}}{13}{figure.8}\protected@file@percent }
\newlabel{fig:lambda-conservation}{{8}{13}{Conservation-law prior: $\lambda _{\mathrm {phys}}$ sensitivity at small (left) and large (right) capacities. Unlike the midpoint prior's smooth degradation, the conservation prior shows non-monotonic behavior with seed-dependent trapping, particularly for the large model at intermediate $\lambda $ values}{figure.8}{}}
\newlabel{fig:lambda-conservation@cref}{{[figure][8][]8}{[1][12][]13}}
