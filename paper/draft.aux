\@writefile{toc}{\contentsline {paragraph}{Comparison across capacities.}{11}{section*.5}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {7.5}Comparative scaling-law fits}{11}{subsection.7.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Error surface $E(N,D)$ for the plain MLP (left), midpoint PIML (center), and composite PIML (right). The plain model shows a smooth gradient from high error (low $N$, low $D$) to low error (high $N$, high $D$). The midpoint PIML is dominated by a uniform plateau near $E \approx 0.015$. The composite PIML recovers a smooth gradient similar to plain, shifted slightly upward by its residual floor.}}{11}{figure.4}\protected@file@percent }
\newlabel{fig:error-heatmap}{{4}{11}{Error surface $E(N,D)$ for the plain MLP (left), midpoint PIML (center), and composite PIML (right). The plain model shows a smooth gradient from high error (low $N$, low $D$) to low error (high $N$, high $D$). The midpoint PIML is dominated by a uniform plateau near $E \approx 0.015$. The composite PIML recovers a smooth gradient similar to plain, shifted slightly upward by its residual floor}{figure.4}{}}
\newlabel{fig:error-heatmap@cref}{{[figure][4][]4}{[1][11][]11}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Fitted scaling exponents with 95\% bootstrap confidence intervals from the joint $E(N,D)$ surface fit. Left: capacity exponent $\alpha $. Right: data exponent $\beta $. The midpoint PIML exponents are substantially compressed, the composite PIML exponents are steeper than plain, and the wide CIs on the composite reflect fewer data points at small capacities.}}{12}{figure.5}\protected@file@percent }
\newlabel{fig:exponent-comparison}{{5}{12}{Fitted scaling exponents with 95\% bootstrap confidence intervals from the joint $E(N,D)$ surface fit. Left: capacity exponent $\alpha $. Right: data exponent $\beta $. The midpoint PIML exponents are substantially compressed, the composite PIML exponents are steeper than plain, and the wide CIs on the composite reflect fewer data points at small capacities}{figure.5}{}}
\newlabel{fig:exponent-comparison@cref}{{[figure][5][]5}{[1][11][]12}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Fitted scaling parameters and failure modes across the four models. 95\% bootstrap confidence intervals are shown in brackets.}}{12}{table.1}\protected@file@percent }
\newlabel{tab:scaling-params}{{1}{12}{Fitted scaling parameters and failure modes across the four models. 95\% bootstrap confidence intervals are shown in brackets}{table.1}{}}
\newlabel{tab:scaling-params@cref}{{[table][1][]1}{[1][12][]12}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.6}Training stability}{12}{subsection.7.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Training stability summary. Left: divergence rate versus dataset size (zero for all three scaling-law models across all configurations). Right: seed-to-seed variance of test error. The midpoint PIML exhibits low variance (converging consistently to the physics-loss plateau), while the plain MLP and composite PIML show higher variance at small $D$.}}{13}{figure.6}\protected@file@percent }
\newlabel{fig:stability}{{6}{13}{Training stability summary. Left: divergence rate versus dataset size (zero for all three scaling-law models across all configurations). Right: seed-to-seed variance of test error. The midpoint PIML exhibits low variance (converging consistently to the physics-loss plateau), while the plain MLP and composite PIML show higher variance at small $D$}{figure.6}{}}
\newlabel{fig:stability@cref}{{[figure][6][]6}{[1][12][]13}}
\@writefile{toc}{\contentsline {subsection}{\numberline {7.7}Sensitivity to regularization strength}{13}{subsection.7.7}\protected@file@percent }
\newlabel{sec:results-lambda}{{7.7}{13}{Sensitivity to regularization strength}{subsection.7.7}{}}
\newlabel{sec:results-lambda@cref}{{[subsection][7][7]7.7}{[1][13][]13}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Midpoint-prior $\lambda _{\mathrm  {phys}}$ sweep: test relative $\ell _2$ error (mean over 9 replicates).}}{13}{table.2}\protected@file@percent }
\newlabel{tab:lambda-midpoint}{{2}{13}{Midpoint-prior $\lambda _{\mathrm {phys}}$ sweep: test relative $\ell _2$ error (mean over 9 replicates)}{table.2}{}}
\newlabel{tab:lambda-midpoint@cref}{{[table][2][]2}{[1][13][]13}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Midpoint-residual prior: $\lambda _{\mathrm  {phys}}$ sensitivity at small (left) and large (right) capacities. The monotonic dose--response pattern is characteristic of a biased prior: increasing $\lambda $ smoothly degrades performance, with no beneficial regime.}}{14}{figure.7}\protected@file@percent }
\newlabel{fig:lambda-midpoint}{{7}{14}{Midpoint-residual prior: $\lambda _{\mathrm {phys}}$ sensitivity at small (left) and large (right) capacities. The monotonic dose--response pattern is characteristic of a biased prior: increasing $\lambda $ smoothly degrades performance, with no beneficial regime}{figure.7}{}}
\newlabel{fig:lambda-midpoint@cref}{{[figure][7][]7}{[1][14][]14}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Conservation-law prior: $\lambda _{\mathrm  {phys}}$ sensitivity at small (left) and large (right) capacities. Unlike the midpoint prior's smooth degradation, the conservation prior shows non-monotonic behavior with seed-dependent trapping, particularly for the large model at intermediate $\lambda $ values.}}{14}{figure.8}\protected@file@percent }
\newlabel{fig:lambda-conservation}{{8}{14}{Conservation-law prior: $\lambda _{\mathrm {phys}}$ sensitivity at small (left) and large (right) capacities. Unlike the midpoint prior's smooth degradation, the conservation prior shows non-monotonic behavior with seed-dependent trapping, particularly for the large model at intermediate $\lambda $ values}{figure.8}{}}
\newlabel{fig:lambda-conservation@cref}{{[figure][8][]8}{[1][14][]14}}
